#include <stdio.h>

int main() {
    int start, end;
    int count3 = 0, count5 = 0;
    int sum3 = 0, sum5 = 0;

    printf("Enter start value: ");
    scanf("%d", &start);

    printf("Enter end value: ");
    scanf("%d", &end);

    // kontrolli i intervalit
    if (start > end) {
        printf("Invalid interval! Start must be <= end.\n");
        return 0;
    }

    for (int i = start; i <= end; i++) {

        // pjesetohet me 3
        if (i % 3 == 0) {
            count3++;
            sum3 += i;
        }
        // pjesetohet me 5 por JO me 3
        else if (i % 5 == 0 && i % 3 != 0) {
            count5++;
            sum5 += i;
        }
    }

    printf("\nInterval: %d to %d\n", start, end);

    printf("Divisible by 3 -> Count: %d, Sum: %d\n", count3, sum3);
    printf("Divisible by 5 (not 3) -> Count: %d, Sum: %d\n", count5, sum5);

    // krahasimi i shumave
    if (sum3 > sum5) {
        printf("Sum of numbers divisible by 3 is greater.\n");
    } else if (sum5 > sum3) {
        printf("Sum of numbers divisible by 5 is greater.\n");
    } else {
        printf("Both sums are equal.\n");
    }

    return 0;
}
