#include <stdio.h>
#include <string.h>

#define MAX 100

enum Status {
    NOT_STARTED = 1,
    IN_PROGRESS,
    COMPLETED
};

struct Student {
    int id;
    char name[50];
    float progress;
    float score;
    enum Status status;
};

struct Student students[MAX];
int count = 0;

// ---------- UTIL FUNCTIONS ----------
void clearInput() {
    while(getchar() != '\n');
}

int isValid(float v) {
    return v >= 0 && v <= 100;
}

char* statusText(enum Status s) {
    switch(s) {
        case NOT_STARTED: return "Not Started";
        case IN_PROGRESS: return "In Progress";
        case COMPLETED: return "Completed";
        default: return "Unknown";
    }
}

void updateIDs() {
    for(int i = 0; i < count; i++) {
        students[i].id = i + 1;
    }
}

int findIndex(int id) {
    for(int i = 0; i < count; i++) {
        if(students[i].id == id) return i;
    }
    return -1;
}

// ---------- PRINT ----------
void printHeader() {
    printf("\n--------------------------------------------------\n");
    printf("ID   Name               Progress   Score   Status\n");
    printf("--------------------------------------------------\n");
}

void printStudent(struct Student s) {
    printf("%-4d %-18s %-10.2f %-7.2f %-15s\n",
           s.id, s.name, s.progress, s.score, statusText(s.status));
}

// ---------- CORE ----------
void addStudent() {
    if(count >= MAX) return;

    students[count].id = count + 1;

    printf("Name: ");
    clearInput();
    fgets(students[count].name, 50, stdin);
    students[count].name[strcspn(students[count].name,"\n")] = 0;

    printf("Progress: ");
    scanf("%f",&students[count].progress);

    printf("Score: ");
    scanf("%f",&students[count].score);

    students[count].status = IN_PROGRESS;

    count++;
    printf("Added.\n");
}

void display() {
    if(count == 0) return;

    printHeader();
    for(int i=0;i<count;i++) {
        printStudent(students[i]);
    }
}

void search() {
    int id;
    printf("Enter ID: ");
    scanf("%d",&id);

    int i = findIndex(id);

    if(i == -1) {
        printf("Not found.\n");
        return;
    }

    printHeader();
    printStudent(students[i]);
}

void updateProgress() {
    int id;
    printf("ID: ");
    scanf("%d",&id);

    int i = findIndex(id);
    if(i == -1) return;

    float *p = &students[i].progress;

    printf("New progress: ");
    scanf("%f",p);

    if(*p == 100) students[i].status = COMPLETED;
}

void edit() {
    int id;
    printf("ID: ");
    scanf("%d",&id);

    int i = findIndex(id);
    if(i == -1) return;

    printf("New name: ");
    clearInput();
    fgets(students[i].name,50,stdin);
    students[i].name[strcspn(students[i].name,"\n")] = 0;

    printf("New score: ");
    scanf("%f",&students[i].score);
}

void deleteRec() {
    int id;
    printf("ID: ");
    scanf("%d",&id);

    int i = findIndex(id);
    if(i == -1) return;

    for(int j=i;j<count-1;j++) {
        students[j] = students[j+1];
    }

    count--;
    updateIDs();
    printf("Deleted.\n");
}

void rank() {
    struct Student temp;

    for(int i=0;i<count-1;i++) {
        for(int j=0;j<count-i-1;j++) {
            if(students[j].progress < students[j+1].progress) {
                temp = students[j];
                students[j] = students[j+1];
                students[j+1] = temp;
            }
        }
    }

    display();
}

// ---------- MENU ----------
void menu() {
    printf("\n1.Add\n2.Show\n3.Search\n4.Update\n5.Edit\n6.Delete\n7.Rank\n8.Exit\n");
}

int main() {
    int op;

    do {
        menu();
        scanf("%d",&op);

        switch(op) {
            case 1: addStudent(); break;
            case 2: display(); break;
            case 3: search(); break;
            case 4: updateProgress(); break;
            case 5: edit(); break;
            case 6: deleteRec(); break;
            case 7: rank(); break;
        }

    } while(op != 8);

    return 0;
}
