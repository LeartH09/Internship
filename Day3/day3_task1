#include <stdio.h>
int main() {
    int n, choice;

    printf("Shkruani nje numer (1 - 12): ");
    scanf("%d", &n);

    if (n < 1 || n > 12) {
        printf("Input i pavlefshem! Ju lutem jepni numer nga 1 deri ne 12.\n");
        return 1;
    }

    printf("Zgjidhni pattern:\n");
    printf("1 - Me yje (*)\n");
    printf("2 - Me numra\n");
    printf("Zgjedhja juaj: ");
    scanf("%d", &choice);

    printf("\nRezultati:\n\n");

    if (choice == 1) {
        for (int i = 1; i <= n; i++) {
            for (int j = 1; j <= i; j++) {
                printf("* ");
            }
            printf("\n");
        }
    }

    else if (choice == 2) {
        for (int i = 1; i <= n; i++) {
            for (int j = 1; j <= i; j++) {
                printf("%d ", j);
            }
            printf("\n");
        }
    }
    else {
        printf("Zgjedhje e pavlefshme!\n");
    }

    return 0;
}
/*
Ky program merr një numër nga përdoruesi (1–12) dhe kontrollon nëse input-i është valid. 
Më pas përdoruesi zgjedh llojin e pattern-it: me yje (*) ose me numra. 
Programi përdor dy for loops një për rreshtat dhe një për elementet brenda rreshtit, 
për të ndërtuar dhe shfaqur pattern-in në mënyrë të rregullt. 
Në rast të input-it të pavlefshëm ose zgjedhjes së gabuar, shfaqet mesazh gabimi.
*/
