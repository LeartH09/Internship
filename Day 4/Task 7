#include <stdio.h>
#include <string.h>

#define MAX 10

enum Status {
    LOW = 1,
    MEDIUM,
    HIGH
};

struct Student {
    int id;
    char name[50];
    double progress;
    enum Status status;
};

void setStatus(struct Student *s) {
    if(s->progress < 40) s->status = LOW;
    else if(s->progress < 70) s->status = MEDIUM;
    else s->status = HIGH;
}

const char* getStatus(enum Status s) {
    switch(s) {
        case LOW: return "LOW";
        case MEDIUM: return "MEDIUM";
        case HIGH: return "HIGH";
        default: return "UNKNOWN";
    }
}

void updateProgress(struct Student *s, double newP) {
    s->progress = newP;
    setStatus(s);
}

void editStudent(struct Student s[], int count) {

    int id;
    printf("Enter ID to edit: ");
    scanf("%d", &id);

    int found = 0;

    for(int i = 0; i < count; i++) {
        if(s[i].id == id) {

            found = 1;

            printf("\nEditing %s\n", s[i].name);

            printf("New Name: ");
            scanf("%s", s[i].name);

            double newP;
            printf("New Progress: ");
            scanf("%lf", &newP);

            updateProgress(&s[i], newP);

            printf("✔ Updated successfully!\n");
        }
    }

    if(!found) {
        printf("Student not found!\n");
    }
}

void deleteStudent(struct Student s[], int *count) {

    int id;
    printf("Enter ID to delete: ");
    scanf("%d", &id);

    int index = -1;

    for(int i = 0; i < *count; i++) {
        if(s[i].id == id) {
            index = i;
            break;
        }
    }

    if(index == -1) {
        printf("Student not found!\n");
        return;
    }


    for(int i = index; i < *count - 1; i++) {
        s[i] = s[i + 1];
    }

    (*count)--;

    printf("✔ Student deleted successfully!\n");
}

void show(struct Student s[], int count) {
    printf("\n--- STUDENTS ---\n");
    for(int i = 0; i < count; i++) {
        printf("\nID: %d\nName: %s\nProgress: %.2lf\nStatus: %s\n",
        s[i].id, s[i].name, s[i].progress, getStatus(s[i].status));
    }
}

void rank(struct Student s[], int count) {

    struct Student temp;

    for(int i = 0; i < count-1; i++) {
        for(int j = 0; j < count-1-i; j++) {
            if(s[j].progress < s[j+1].progress) {
                temp = s[j];
                s[j] = s[j+1];
                s[j+1] = temp;
            }
        }
    }

    printf("\n--- RANKING ---\n");
    for(int i = 0; i < count; i++) {
        printf("%d. %s (%.2lf)\n", i+1, s[i].name, s[i].progress);
    }
}

int main() {

    struct Student s[MAX] = {
        {1,"Ardi",75.5,HIGH},
        {2,"Luan",60.0,MEDIUM},
        {3,"Era",35.0,LOW},
        {4,"Sara",90.0,HIGH}
    };

    int count = 4;
    int choice;

    while(1) {

        printf("\n====== MENU ======\n");
        printf("1. Show\n");
        printf("2. Add\n");
        printf("3. Edit (UPDATE)\n");
        printf("4. Delete\n");
        printf("5. Ranking\n");
        printf("6. Exit\n");
        printf("==================\n");
        printf("Choice: ");
        scanf("%d", &choice);

        switch(choice) {

            case 1:
                show(s, count);
                break;

            case 2:
                if(count >= MAX) {
                    printf("Max reached!\n");
                    break;
                }

                printf("ID: ");
                scanf("%d", &s[count].id);

                printf("Name: ");
                scanf("%s", s[count].name);

                printf("Progress: ");
                scanf("%lf", &s[count].progress);

                setStatus(&s[count]);

                count++;
                printf("Added!\n");
                break;

            case 3:
                editStudent(s, count);
                break;

            case 4:
                deleteStudent(s, &count);
                break;

            case 5:
                rank(s, count);
                break;

            case 6:
                printf("Exiting...\n");
                return 0;

            default:
                printf("Invalid option!\n");
        }
    }
}
