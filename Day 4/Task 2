#include <stdio.h>
#include <string.h>

#define MAX 5

enum Status {
    LOW = 1,
    MEDIUM,
    HIGH
};

struct Student {
    int id;
    char name[50];
    double progress;
    enum Status status;
};

const char* getStatusText(enum Status s) {
    switch(s) {
        case LOW: return "LOW";
        case MEDIUM: return "MEDIUM";
        case HIGH: return "HIGH";
        default: return "UNKNOWN";
    }
}

int main() {

    struct Student students[MAX] = {
        {1, "Milot", 85.5, HIGH},
        {2, "Ardi", 60.0, MEDIUM},
        {3, "Luan", 30.0, LOW}
    };

    int count = 3; 
    int choice;

    while(1) {

        printf("\n--- MENU ---\n");
        printf("1. Add Student\n");
        printf("2. Show Students\n");
        printf("3. Exit\n");
        printf("Choice: ");

        if(scanf("%d", &choice) != 1) {
            printf("Invalid input! Try again.\n");
            while(getchar() != '\n');
            continue;
        }

        switch(choice) {

            case 1:
                if(count >= MAX) {
                    printf("Maximum capacity reached!\n");
                    break;
                }

                printf("Enter ID: ");
                scanf("%d", &students[count].id);

                printf("Enter Name: ");
                scanf("%s", students[count].name);

                printf("Enter Progress (0-100): ");
                scanf("%lf", &students[count].progress);

                int statusChoice;

                printf("\nSelect Status:\n");
                printf("1. LOW\n2. MEDIUM\n3. HIGH\n");
                printf("Choice: ");

                scanf("%d", &statusChoice);

                switch(statusChoice) {
                    case 1:
                        students[count].status = LOW;
                        break;
                    case 2:
                        students[count].status = MEDIUM;
                        break;
                    case 3:
                        students[count].status = HIGH;
                        break;
                    default:
                        printf("Invalid status! Setting LOW.\n");
                        students[count].status = LOW;
                }

                count++;
                printf("Student added successfully!\n");
                break;

            case 2:
                if(count == 0) {
                    printf("No records available.\n");
                    break;
                }

                printf("\n--- STUDENTS ---\n");

                for(int i = 0; i < count; i++) {
                    printf("\nStudent %d\n", i+1);
                    printf("ID: %d\n", students[i].id);
                    printf("Name: %s\n", students[i].name);
                    printf("Progress: %.2lf\n", students[i].progress);
                    printf("Status: %s\n", getStatusText(students[i].status));
                }

                printf("\nTotal: %d / %d\n", count, MAX);
                break;

            case 3:
                printf("Exiting program...\n");
                return 0;

            default:
                printf("Invalid menu choice!\n");
        }
    }

    return 0;
}
