#include <stdio.h>
#include <string.h>

#define MAX 10

enum Status {
    LOW = 1,
    MEDIUM,
    HIGH
};

struct Student {
    int id;
    char name[50];
    double progress;
    enum Status status;
};

void setStatus(struct Student *s) {
    if(s->progress < 40)
        s->status = LOW;
    else if(s->progress < 70)
        s->status = MEDIUM;
    else
        s->status = HIGH;
}


void updateProgress(struct Student *s, double newP) {
    printf("\nOld progress: %.2lf\n", s->progress);
    s->progress = newP;
    setStatus(s);
    printf("New progress: %.2lf\n", s->progress);
}

const char* getStatus(enum Status s) {
    switch(s) {
        case LOW: return "LOW";
        case MEDIUM: return "MEDIUM";
        case HIGH: return "HIGH";
        default: return "UNKNOWN";
    }
}


void showStudents(struct Student s[], int count) {
    printf("\n--- STUDENTS ---\n");
    for(int i = 0; i < count; i++) {
        printf("\nID: %d\nName: %s\nProgress: %.2lf\nStatus: %s\n",
        s[i].id, s[i].name, s[i].progress, getStatus(s[i].status));
    }
}


void report(struct Student s[], int count) {

    if(count == 0) {
        printf("No data!\n");
        return;
    }

    int low=0, med=0, high=0;
    double sum=0;

    for(int i=0;i<count;i++) {
        sum += s[i].progress;

        if(s[i].progress < 40) low++;
        else if(s[i].progress < 70) med++;
        else high++;
    }

    printf("\n--- REPORT ---\n");
    printf("Total: %d\n", count);
    printf("LOW: %d | MEDIUM: %d | HIGH: %d\n", low, med, high);
    printf("Average: %.2lf\n", sum/count);
}


void search(struct Student s[], int count) {
    int id;
    printf("Enter ID to search: ");
    scanf("%d", &id);

    int found = 0;

    for(int i=0;i<count;i++) {
        if(s[i].id == id) {
            found = 1;

            printf("\nFOUND:\n");
            printf("Name: %s\nProgress: %.2lf\n", s[i].name, s[i].progress);

            if(s[i].progress < 40)
                printf("⚠ Warning: Low performance\n");
            else if(s[i].progress < 70)
                printf("Note: Needs improvement\n");
            else
                printf("Good performance\n");
        }
    }

    if(!found) printf("Not found!\n");
}

void rankStudents(struct Student s[], int count) {

    struct Student temp;

    for(int i=0;i<count-1;i++) {
        for(int j=0;j<count-1-i;j++) {

            if(s[j].progress < s[j+1].progress) {

                temp = s[j];
                s[j] = s[j+1];
                s[j+1] = temp;
            }
        }
    }

    printf("\n--- RANKING (BEST → WORST) ---\n");

    for(int i=0;i<count;i++) {
        printf("%d. %s (%.2lf)\n", i+1, s[i].name, s[i].progress);
    }
}

int main() {

    struct Student s[MAX] = {
        {1,"Ardi",75.5,HIGH},
        {2,"Luan",60.0,MEDIUM},
        {3,"Era",35.0,LOW},
        {4,"Sara",90.0,HIGH},
        {5,"Dren",45.0,MEDIUM}
    };

    int count = 5;
    int choice;

    while(1) {

        printf("\n====== MENU ======\n");
        printf("1. Add Student\n");
        printf("2. Show Students\n");
        printf("3. Report\n");
        printf("4. Search\n");
        printf("5. Update (Pointer)\n");
        printf("6. Ranking\n");
        printf("7. Exit\n");
        printf("==================\n");
        printf("Choice: ");
        scanf("%d", &choice);

        switch(choice) {

            case 1:
                if(count >= MAX) {
                    printf("Max reached!\n");
                    break;
                }

                printf("ID: ");
                scanf("%d", &s[count].id);

                printf("Name: ");
                scanf("%s", s[count].name);

                printf("Progress: ");
                scanf("%lf", &s[count].progress);

                setStatus(&s[count]);
                count++;

                printf("Added!\n");
                break;

            case 2:
                showStudents(s, count);
                break;

            case 3:
                report(s, count);
                break;

            case 4:
                search(s, count);
                break;

            case 5: {
                int id;
                double newP;

                printf("Enter ID: ");
                scanf("%d", &id);

                for(int i=0;i<count;i++) {
                    if(s[i].id == id) {
                        printf("New progress: ");
                        scanf("%lf", &newP);

                        updateProgress(&s[i], newP);
                    }
                }
                break;
            }

            case 6:
                rankStudents(s, count);
                break;

            case 7:
                printf("Exiting...\n");
                return 0;

            default:
                printf("Invalid!\n");
        }
    }
}
