#include <stdio.h>
#include <string.h>

#define MAX 5

struct Student {
    int id;
    char name[50];
    double progress;
};

int main() {

    struct Student students[MAX] = {
        {1, "Ardi", 75.5},
        {2, "Luan", 60.0},
        {3, "Era", 40.0}
    };

    int count = 3;
    int choice;

    while(1) {
        printf("\n--- MENU ---\n");
        printf("1. Add Student\n");
        printf("2. Show Students\n");
        printf("3. Exit\n");
        printf("Choice: ");
        scanf("%d", &choice);

        switch(choice) {

            case 1:
                if(count >= MAX) {
                    printf("Max limit reached!\n");
                    break;
                }

                printf("Enter ID: ");
                scanf("%d", &students[count].id);

                printf("Enter Name: ");
                scanf("%s", students[count].name);

                printf("Enter Progress: ");
                scanf("%lf", &students[count].progress);

                count++;
                printf("Student added!\n");
                break;

            case 2:
                if(count == 0) {
                    printf("No data!\n");
                    break;
                }

                for(int i = 0; i < count; i++) {
                    printf("\nStudent %d\n", i+1);
                    printf("ID: %d\n", students[i].id);
                    printf("Name: %s\n", students[i].name);
                    printf("Progress: %.2lf\n", students[i].progress);
                }
                break;

            case 3:
                return 0;

            default:
                printf("Invalid choice!\n");
        }
    }
}
