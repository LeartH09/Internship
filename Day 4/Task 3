#include <stdio.h>
#include <string.h>

#define MAX 5

enum Status {
    LOW = 1,
    MEDIUM,
    HIGH
};

struct Student {
    int id;
    char name[50];
    double progress;
    enum Status status;
};

void setStatus(struct Student *s) {
    if(s->progress < 40)
        s->status = LOW;
    else if(s->progress < 70)
        s->status = MEDIUM;
    else
        s->status = HIGH;
}

const char* getStatusText(enum Status s) {
    switch(s) {
        case LOW: return "LOW";
        case MEDIUM: return "MEDIUM";
        case HIGH: return "HIGH";
        default: return "UNKNOWN";
    }
}

void showReport(struct Student students[], int count) {

    if(count == 0) {
        printf("\n--- REPORT ---\n");
        printf("No data available!\n");
        return;
    }

    double sum = 0;
    double max = students[0].progress;
    double min = students[0].progress;

    int completed = 0;

    for(int i = 0; i < count; i++) {

        sum += students[i].progress;

        if(students[i].progress > max)
            max = students[i].progress;

        if(students[i].progress < min)
            min = students[i].progress;

        if(students[i].progress >= 50)
            completed++;
    }

    double avg = sum / count;

    printf("\n========== REPORT ==========\n");
    printf("Total Students: %d\n", count);
    printf("Completed (>=50): %d\n", completed);

    if(avg >= 70)
        printf("Average Progress: %.2lf (GOOD)\n", avg);
    else if(avg >= 40)
        printf("Average Progress: %.2lf (MEDIUM)\n", avg);
    else
        printf("Average Progress: %.2lf (LOW)\n", avg);

    printf("Highest Progress: %.2lf\n", max);
    printf("Lowest Progress: %.2lf\n", min);
    printf("============================\n");
}

int main() {

    struct Student students[MAX] = {
        {1, "Ardi", 75.5, HIGH},
        {2, "Luan", 60.0, MEDIUM},
        {3, "Era", 40.0, LOW}
    };

    int count = 3;
    int choice;

    while(1) {

        printf("\n--- MENU ---\n");
        printf("1. Add Student\n");
        printf("2. Show Students\n");
        printf("3. Show Report\n");
        printf("4. Exit\n");
        printf("Choice: ");
        scanf("%d", &choice);

        switch(choice) {

            case 1:
                if(count >= MAX) {
                    printf("Max limit reached!\n");
                    break;
                }

                printf("Enter ID: ");
                scanf("%d", &students[count].id);

                printf("Enter Name: ");
                scanf("%s", students[count].name);

                printf("Enter Progress: ");
                scanf("%lf", &students[count].progress);

                setStatus(&students[count]);

                count++;
                printf("Student added!\n");
                break;

            case 2:
                if(count == 0) {
                    printf("No data!\n");
                    break;
                }

                for(int i = 0; i < count; i++) {
                    printf("\nStudent %d\n", i+1);
                    printf("ID: %d\n", students[i].id);
                    printf("Name: %s\n", students[i].name);
                    printf("Progress: %.2lf\n", students[i].progress);
                    printf("Status: %s\n", getStatusText(students[i].status));
                }
                break;

            case 3:
                showReport(students, count);
                break;

            case 4:
                return 0;

            default:
                printf("Invalid choice!\n");
        }
    }
}
