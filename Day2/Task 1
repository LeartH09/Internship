#include <stdio.h>

int main() {
 
    int age = 17;
    char initial = 'M';
    float height = 168.0;   // në cm
    double average = 4.7;

    short year = 2026;
    double population = 8.3; // miliardë (B)

   
    printf("\n--- USER PROFILE ---\n");
    printf("Age: %d\n", age);
    printf("Initial: %c\n", initial);
    printf("Height: %.1f cm\n", height);
    printf("Average: %.1lf\n", average);
    printf("Year (short): %d\n", year);
    printf("Population: %.1lf B\n", population);

    return 0;
}
