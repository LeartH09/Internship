#include <stdio.h>

int main() {
    int age, option;
    char initial;
    double points;

    // Input
    printf("Enter your age: ");
    scanf("%d", &age);

    printf("Enter your initial: ");
    scanf(" %c", &initial);

    printf("Enter your points: ");
    scanf("%lf", &points);

    printf("Choose workshop (1-3): ");
    scanf("%d", &option);

    // Kontroll moshe
    if (age < 15 || age > 25) {
        printf("\nNot eligible to participate.\n");
    } else {
        printf("\nEligible to participate.\n");
    }

    // Klasifikimi me if/else
    if (points < 50) {
        printf("Level: Needs more practice\n");
    } else if (points < 80) {
        printf("Level: Ready to continue\n");
    } else {
        printf("Level: Ready for challenge\n");
    }

    // Workshop me switch
    printf("Workshop: ");
    switch(option) {
        case 1:
            printf("Programming Basics\n");
            break;
        case 2:
            printf("Web Development\n");
            break;
        case 3:
            printf("Data Science\n");
            break;
        default:
            printf("Invalid option\n");
    }

    // Output final
    printf("\n--- Summary ---\n");
    printf("Age: %d\n", age);
    printf("Initial: %c\n", initial);
    printf("Points: %.2lf\n", points);
    printf("Option: %d\n", option);

    return 0;
}