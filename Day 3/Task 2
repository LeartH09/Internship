#include <stdio.h>

int main() {

    int start, end;
    int evenCount = 0, oddCount = 0;
    int evenSum = 0, oddSum = 0;

    // Marrja e input-it
    printf("Enter start of interval: ");
    scanf("%d", &start);

    printf("Enter end of interval: ");
    scanf("%d", &end);

    // Kontrolli i intervalit
    if(start > end) {
        printf("Invalid interval! Start must be less than or equal to end.\n");
        return 0;
    }

    // For loop për analizë
    for(int i = start; i <= end; i++) {

        if(i % 2 == 0) {
            evenCount++;
            evenSum += i;
        } else {
            oddCount++;
            oddSum += i;
        }
    }

    int totalNumbers = end - start + 1;

    // Output
    printf("\n--- RESULT ---\n");
    printf("Interval: %d to %d\n", start, end);
    printf("Total numbers: %d\n", totalNumbers);

    printf("\nEven numbers: %d\n", evenCount);
    printf("Sum of even numbers: %d\n", evenSum);

    printf("\nOdd numbers: %d\n", oddCount);
    printf("Sum of odd numbers: %d\n", oddSum);

    // Krahasimi
    if(evenCount > oddCount) {
        printf("\nMore even numbers in this interval.\n");
    }
    else if(oddCount > evenCount) {
        printf("\nMore odd numbers in this interval.\n");
    }
    else {
        printf("\nEqual number of even and odd numbers.\n");
    }

    return 0;
}
