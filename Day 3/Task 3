#include <stdio.h>

int main() {

    // Data të vendosura
    int start = 5;
    int end = 40;

    int count3 = 0, sum3 = 0;
    int count5 = 0, sum5 = 0;

    // Kontrolli i intervalit
    if(start > end) {
        printf("Invalid interval!\n");
        return 0;
    }

    // Analiza me for loop
    for(int i = start; i <= end; i++) {

        // Numrat që pjesëtohen me 3
        if(i % 3 == 0) {
            count3++;
            sum3 += i;
        }
        // Numrat që pjesëtohen me 5 por jo me 3
        else if(i % 5 == 0) {
            count5++;
            sum5 += i;
        }
    }

    // Output
    printf("\n--- RESULT ---\n");
    printf("Interval: %d to %d\n", start, end);

    printf("\nDivisible by 3:\n");
    printf("Count: %d\n", count3);
    printf("Sum: %d\n", sum3);

    printf("\nDivisible by 5 (not 3):\n");
    printf("Count: %d\n", count5);
    printf("Sum: %d\n", sum5);

    // Krahasimi i shumave
    if(sum3 > sum5) {
        printf("\nSum of numbers divisible by 3 is greater.\n");
    }
    else if(sum5 > sum3) {
        printf("\nSum of numbers divisible by 5 is greater.\n");
    }
    else {
        printf("\nBoth sums are equal.\n");
    }

    return 0;
}
