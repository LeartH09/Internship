#include <stdio.h>

enum Level {BEGINNER = 1, INTERMEDIATE, ADVANCED, EXPERT};

int main() {

    int choices[3] = {1, 3, 5}; // 5 = invalid

    int validCount = 0;
    int invalidCount = 0;

    printf("--- PROCESSING USERS ---\n");

    for(int i = 0; i < 3; i++) {

        int input = choices[i];
        printf("\nUser %d selected: %d\n", i + 1, input);

        switch(input) {

            case BEGINNER:
                printf("Level: Beginner - Keep learning basics.\n");
                validCount++;
                break;

            case INTERMEDIATE:
                printf("Level: Intermediate - You are improving.\n");
                validCount++;
                break;

            case ADVANCED:
                printf("Level: Advanced - Strong skills.\n");
                validCount++;
                break;

            case EXPERT:
                printf("Level: Expert - Excellent performance.\n");
                validCount++;
                break;

            default:
                printf("Invalid choice!\n");
                invalidCount++;
        }
    }

    printf("\n--- STATISTICS ---\n");
    printf("Valid choices: %d\n", validCount);
    printf("Invalid choices: %d\n", invalidCount);

    return 0;
}
